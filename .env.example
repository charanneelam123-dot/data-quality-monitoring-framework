# =============================================================================
# Data Quality Monitoring Framework — Environment Variables
# =============================================================================
# Copy to .env (git-ignored) and fill in real values.
# Loaded automatically by python-dotenv or your CI/CD secrets manager.
# =============================================================================

# ── Runtime environment ────────────────────────────────────────────────────────
ENVIRONMENT=dev                           # dev | staging | prod

# ── Slack alerting ────────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=replace-with-your-slack-incoming-webhook-url

# ── Email alerting (SMTP) ─────────────────────────────────────────────────────
SMTP_HOST=smtp.company.com
SMTP_USER=dq-alerts@company.com
SMTP_PASSWORD=your-smtp-password

# ── AWS (for Glue / S3 / Redshift-based pipelines) ────────────────────────────
AWS_DEFAULT_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY

# ── Databricks (for Databricks-hosted pipelines) ──────────────────────────────
DATABRICKS_HOST=https://your-workspace.azuredatabricks.net
DATABRICKS_TOKEN=dapiXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Snowflake (for dbt / Snowflake pipelines) ─────────────────────────────────
SNOWFLAKE_ACCOUNT=your-account.region
SNOWFLAKE_USER=dq_service
SNOWFLAKE_PASSWORD=your-snowflake-password
SNOWFLAKE_WAREHOUSE=TRANSFORM_WH
SNOWFLAKE_DATABASE=ANALYTICS
SNOWFLAKE_SCHEMA=DQ_MONITORING

# ── DQ Framework config ────────────────────────────────────────────────────────
DQ_CONFIG_PATH=config/thresholds.yml     # path to your YAML config
DQ_METRICS_TABLE=dq.volume_history       # optional Delta table for volume history
